{
  "name": "picolight",
  "version": "0.2.8",
  "description": "The tiny syntax highlighting library",
  "repository": "https://github.com/raviqqe/picolight",
  "license": "MIT",
  "publishConfig": {
    "provenance": true
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./languages/*": {
      "types": "./dist/languages/*.d.ts",
      "default": "./dist/languages/*.js"
    },
    "./languages/experimental/*": {
      "types": "./dist/languages/experimental/*.d.ts",
      "default": "./dist/languages/experimental/*.js"
    },
    "./themes/*": {
      "types": "./dist/themes/*.d.ts",
      "default": "./dist/themes/*.js"
    }
  },
  "scripts": {
    "build": "node --run build:languages && node --run build:themes && tsdown",
    "build:languages": "tsx src/scripts/build-languages.ts",
    "build:themes": "tsx src/scripts/build-themes.ts",
    "lint": "knip",
    "test": "vitest --coverage"
  },
  "devDependencies": {
    "@raviqqe/tsconfig": "^3.0.1",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "es-toolkit": "^1.46.1",
    "jsdom": "^29.1.1",
    "knip": "^6.13.1",
    "oniguruma-to-es": "^4.3.6",
    "tm-grammars": "^1.31.15",
    "tm-themes": "^1.12.2",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "valibot": "^1.4.0",
    "vitest": "^4.1.6",
    "zod": "^4.4.3"
  }
}
